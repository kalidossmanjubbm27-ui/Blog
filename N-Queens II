class Solution {
public:
    int totalNQueens(int n) {
        return backtrack(n, 0, 0, 0, 0);
    }

private:
    int backtrack(int n, int row, int cols, int diag1, int diag2) {
        if (row == n)
            return 1;

        int count = 0;
        int available = ((1 << n) - 1) & ~(cols | diag1 | diag2);

        while (available) {
            int position = available & -available;
            available -= position;

            count += backtrack(
                n,
                row + 1,
                cols | position,
                (diag1 | position) << 1,
                (diag2 | position) >> 1
            );
        }

        return count;
    }
};   // ✅ IMPORTANT — this closes the class properly
